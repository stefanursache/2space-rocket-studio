{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "functions": {
        "api/index.ts": {
            "includeFiles": "server/src/**",
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        }
    ]
}